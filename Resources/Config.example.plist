<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- このファイルをコピーして Config.plist を作成し、実際のAPIキーを設定してください。 -->
    <!-- Config.plist は .gitignore 済みでコミットされません。 -->
    <key>YOUTUBE_API_KEY</key>
    <string>YOUR_API_KEY_HERE</string>

    <!-- プライバシーポリシーのURL（App Store提出時に設定）。未設定なら情報画面にリンクを表示しない。 -->
    <key>PRIVACY_POLICY_URL</key>
    <string>YOUR_PRIVACY_POLICY_URL_HERE</string>
</dict>
</plist>
